            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (orange_book_init_region
          (:target study_table)
          (:ranges (
              (0.129 -0.081 0.191 -0.019000000000000003)
            )
          )
          (:yaw_rotation (
