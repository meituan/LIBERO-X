    (On black_book_1 study_table_black_book_A_init_region)
    (On black_book_2 study_table_black_book_B_init_region)
    (On yellow_book_1 study_table_yellow_book_init_region)
    (On white_yellow_mug_1 study_table_white_yellow_mug_init_region)
    (On bbq_sauce_1 study_table_bbq_sauce_init_region)
  )

  (:goal
    (And (ExactIn yellow_book_1 desk_caddy_right_1_front_contain_region) (ExactIn black_book_1 desk_caddy_right_1_left_contain_region) (ExactIn black_book_2 desk_caddy_right_1_back_contain_region))
  )

)
