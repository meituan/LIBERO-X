    )

  (:fixtures
    study_table - study_table
  )

  (:objects
    black_book_1 black_book_2 - black_book
    yellow_book_1 - yellow_book
    white_yellow_mug_1 - white_yellow_mug
    red_coffee_mug_1 - red_coffee_mug
    desk_caddy_back_1 - desk_caddy_back
    plate_1 - plate
    chocolate_pudding_1 - chocolate_pudding
    milk_1 - milk
  )

  (:obj_of_interest
    black_book_1
    yellow_book_1
    black_book_2
    desk_caddy_back_1
  )

  (:init
    (On desk_caddy_back_1 study_table_desk_caddy_back_init_region)
    (On black_book_1 study_table_black_book_A_init_region)
    (On black_book_2 study_table_black_book_B_init_region)
    (On yellow_book_1 study_table_yellow_book_init_region)
    (On white_yellow_mug_1 study_table_white_yellow_mug_init_region)
    (On red_coffee_mug_1 study_table_red_coffee_mug_init_region)
    (On plate_1 study_table_plate_init_region)
  )

  (:goal
    (And (ExactIn black_book_1 desk_caddy_back_1_left_contain_region) (ExactIn yellow_book_1 desk_caddy_back_1_right_contain_region) (ExactIn black_book_2 desk_caddy_back_1_right_contain_region))
  )

)
