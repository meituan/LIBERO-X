              (0.015 -0.245 0.085 -0.175)
            )
          )
          (:yaw_rotation (
              (-3.142 3.142)
            )
          )
      )
      (porcelain_mug_init_region
          (:target study_table)
          (:ranges (
              (0.347 0.23099999999999998 0.377 0.261)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
