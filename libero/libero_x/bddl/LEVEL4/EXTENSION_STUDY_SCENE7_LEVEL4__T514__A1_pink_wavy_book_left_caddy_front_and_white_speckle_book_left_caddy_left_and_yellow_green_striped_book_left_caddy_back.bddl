    (On desk_caddy_1 study_table_desk_caddy_init_region)
    (On white_speckle_book_1 study_table_white_speckle_book_init_region)
    (On yellow_green_striped_book_1 study_table_yellow_green_striped_book_init_region)
    (On pink_wavy_book_1 study_table_pink_wavy_book_init_region)
    (On striped_book_1 study_table_striped_book_init_region)
    (On green_book_1 study_table_green_book_init_region)
    (On porcelain_mug_1 study_table_porcelain_mug_init_region)
  )

  (:goal
