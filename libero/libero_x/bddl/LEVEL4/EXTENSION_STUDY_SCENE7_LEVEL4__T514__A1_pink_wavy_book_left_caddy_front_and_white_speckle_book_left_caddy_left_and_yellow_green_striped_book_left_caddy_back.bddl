      )
      (back_contain_region
          (:target desk_caddy_1)
      )
      (front_contain_region
          (:target desk_caddy_1)
      )
    )

  (:fixtures
    study_table - study_table
  )

  (:objects
    yellow_green_striped_book_1 - yellow_green_striped_book
    pink_wavy_book_1 - pink_wavy_book
    white_yellow_mug_1 - white_yellow_mug
    desk_caddy_1 - desk_caddy
    white_speckle_book_1 - white_speckle_book
    striped_book_1 - striped_book
    green_book_1 - green_book
    porcelain_mug_1 - porcelain_mug
  )

  (:obj_of_interest
