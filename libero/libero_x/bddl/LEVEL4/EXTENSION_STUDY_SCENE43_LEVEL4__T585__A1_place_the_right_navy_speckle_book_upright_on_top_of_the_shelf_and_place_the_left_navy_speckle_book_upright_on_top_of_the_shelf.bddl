    (On navy_speckle_book_1 study_table_navy_speckle_book_A_init_region)
    (On navy_speckle_book_2 study_table_navy_speckle_book_B_init_region)
    (On yellow_book_1 study_table_yellow_book_init_region)
    (On white_yellow_mug_1 study_table_white_yellow_mug_init_region)
    (On bbq_sauce_1 study_table_bbq_sauce_init_region)
    (On porcelain_mug_1 study_table_porcelain_mug_init_region)
    (On akita_yellow_bowl_1 study_table_akita_yellow_bowl_init_region)
  )

  (:goal
    (And (UprightOn navy_speckle_book_1 wooden_two_layer_shelf_1_top_side) (UprightOn navy_speckle_book_2 wooden_two_layer_shelf_1_top_side))
  )

)
