  (:fixtures
    study_table - study_table
  )

  (:objects
    navy_speckle_book_1 navy_speckle_book_2 - navy_speckle_book
    yellow_book_1 - yellow_book
    white_yellow_mug_1 - white_yellow_mug
    wooden_two_layer_shelf_1 - wooden_two_layer_shelf
    bbq_sauce_1 - bbq_sauce
    porcelain_mug_1 - porcelain_mug
    akita_yellow_bowl_1 - akita_yellow_bowl
  )

  (:obj_of_interest
    navy_speckle_book_1
    navy_speckle_book_2
    wooden_two_layer_shelf_1
  )

  (:init
