    (On orange_juice_1 study_table_orange_juice_A_init_region)
    (On orange_juice_2 study_table_orange_juice_B_init_region)
    (On yellow_book_1 study_table_yellow_book_init_region)
    (On macaroni_and_cheese_1 study_table_macaroni_and_cheese_init_region)
    (On chocolate_pudding_1 study_table_chocolate_pudding_init_region)
  )

  (:goal
    (And (On orange_juice_1 wooden_two_layer_shelf_1_top_side) (On macaroni_and_cheese_1 wooden_two_layer_shelf_1_top_side))
  )

)
