              (0.11399999999999999 -0.016 0.246 0.116)
            )
          )
          (:yaw_rotation (
              (-3.142 3.142)
            )
          )
      )
      (white_yellow_mug_init_region
          (:target study_table)
          (:ranges (
              (-0.17 -0.28 -0.03 -0.13999999999999999)
            )
          )
          (:yaw_rotation (
              (-3.142 3.142)
            )
          )
      )
      (pink_wavy_book_init_region
