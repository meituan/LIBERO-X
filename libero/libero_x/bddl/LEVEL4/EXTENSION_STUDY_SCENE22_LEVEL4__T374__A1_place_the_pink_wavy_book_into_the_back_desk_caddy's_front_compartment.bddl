    (On black_book_1 study_table_black_book_init_region)
    (On pink_wavy_book_1 study_table_pink_wavy_book_init_region)
    (On white_yellow_mug_1 study_table_white_yellow_mug_init_region)
    (On red_coffee_mug_1 study_table_red_coffee_mug_init_region)
    (On akita_blue_bowl_1 study_table_akita_blue_bowl_init_region)
    (On tomato_sauce_1 study_table_tomato_sauce_init_region)
