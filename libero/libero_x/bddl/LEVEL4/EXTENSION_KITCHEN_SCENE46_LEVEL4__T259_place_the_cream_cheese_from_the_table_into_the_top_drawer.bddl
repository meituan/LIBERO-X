(define (problem LIBERO_Kitchen_Tabletop_Manipulation)
  (:domain robosuite)
  (:language place the cream cheese from the table into the top drawer)
    (:regions
      (white_cabinet_init_region
          (:target kitchen_table)
          (:ranges (
              (-0.18 0.21999999999999997 -0.020000000000000004 0.38)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (cream_cheese_2_init_region
          (:target kitchen_table)
          (:ranges (
              (0.053000000000000005 0.0030000000000000027 0.14700000000000002 0.097)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (wine_rack_init_region
          (:target kitchen_table)
          (:ranges (
              (-0.075 -0.275 0.075 -0.125)
            )
          )
          (:yaw_rotation (
              (3.142 3.142)
            )
          )
      )
      (yellow_book_init_region
          (:target kitchen_table)
          (:ranges (
              (0.20600000000000002 -0.015 0.236 0.015)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (akita_yellow_bowl_init_region
          (:target kitchen_table)
          (:ranges (
              (-0.35300000000000004 0.26999999999999996 -0.323 0.3)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (top_region
          (:target wine_rack_1)
      )
      (top_side
          (:target white_cabinet_1)
      )
      (top_region
          (:target white_cabinet_1)
      )
      (middle_region
          (:target white_cabinet_1)
      )
      (bottom_region
          (:target white_cabinet_1)
      )
    )

  (:fixtures
    kitchen_table - kitchen_table
    wine_rack_1 - wine_rack
    white_cabinet_1 - white_cabinet
  )

  (:objects
    cream_cheese_1 cream_cheese_2 - cream_cheese
    yellow_book_1 - yellow_book
    akita_yellow_bowl_1 - akita_yellow_bowl
  )

  (:obj_of_interest
    white_cabinet_1
    cream_cheese_2
  )

  (:init
    (On wine_rack_1 kitchen_table_wine_rack_init_region)
    (In cream_cheese_1 white_cabinet_1_top_region)
    (On cream_cheese_2 kitchen_table_cream_cheese_2_init_region)
    (Open white_cabinet_1_top_region)
    (On white_cabinet_1 kitchen_table_white_cabinet_init_region)
    (On yellow_book_1 kitchen_table_yellow_book_init_region)
    (On akita_yellow_bowl_1 kitchen_table_akita_yellow_bowl_init_region)
  )

  (:goal
    (And (In cream_cheese_2 white_cabinet_1_top_region))
  )

)
