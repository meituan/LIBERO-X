    (On yellow_green_striped_book_1 study_table_yellow_green_striped_book_A_init_region)
    (On red_coffee_mug_1 study_table_red_coffee_mug_init_region)
    (On yellow_green_striped_book_2 study_table_yellow_green_striped_book_B_init_region)
    (On orange_book_1 study_table_orange_book_init_region)
    (On striped_book_1 study_table_striped_book_init_region)
    (On milk_1 study_table_milk_init_region)
  )

  (:goal
