    (On red_coffee_mug_1 study_table_red_coffee_mug_init_region)
    (On red_book_1 study_table_red_book_init_region)
    (On orange_book_1 study_table_orange_book_init_region)
    (On teal_wavy_book_1 study_table_teal_wavy_book_init_region)
    (On orange_juice_1 study_table_orange_juice_init_region)
  )

  (:goal
    (And (ExactIn teal_wavy_book_1 desk_caddy_back_1_right_contain_region))
  )

)
