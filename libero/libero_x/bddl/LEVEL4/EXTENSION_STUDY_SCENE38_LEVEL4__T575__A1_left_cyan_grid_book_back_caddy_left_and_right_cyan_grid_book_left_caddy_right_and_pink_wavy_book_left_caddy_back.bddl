            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (tomato_sauce_init_region
          (:target study_table)
          (:ranges (
              (0.258 -0.322 0.28800000000000003 -0.292)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (akita_green_bowl_init_region
          (:target study_table)
          (:ranges (
              (0.11900000000000001 0.33499999999999996 0.14900000000000002 0.365)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
