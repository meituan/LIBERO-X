      (back_contain_region
          (:target desk_caddy_back_1)
      )
      (front_contain_region
          (:target desk_caddy_back_1)
      )
    )

  (:fixtures
    study_table - study_table
  )

  (:objects
    desk_caddy_1 - desk_caddy
    desk_caddy_back_1 - desk_caddy_back
    cyan_grid_book_1 cyan_grid_book_2 - cyan_grid_book
    pink_wavy_book_1 - pink_wavy_book
    striped_book_1 - striped_book
    tomato_sauce_1 - tomato_sauce
    akita_green_bowl_1 - akita_green_bowl
  )

  (:obj_of_interest
    cyan_grid_book_2
    cyan_grid_book_1
    pink_wavy_book_1
    desk_caddy_1
    desk_caddy_back_1
  )

  (:init
    (On desk_caddy_1 study_table_desk_caddy_init_region)
    (On desk_caddy_back_1 study_table_desk_caddy_back_init_region)
    (On cyan_grid_book_1 study_table_cyan_grid_book_A_init_region)
    (On cyan_grid_book_2 study_table_cyan_grid_book_B_init_region)
    (On pink_wavy_book_1 study_table_pink_wavy_book_init_region)
    (On striped_book_1 study_table_striped_book_init_region)
    (On tomato_sauce_1 study_table_tomato_sauce_init_region)
    (On akita_green_bowl_1 study_table_akita_green_bowl_init_region)
  )

  (:goal
