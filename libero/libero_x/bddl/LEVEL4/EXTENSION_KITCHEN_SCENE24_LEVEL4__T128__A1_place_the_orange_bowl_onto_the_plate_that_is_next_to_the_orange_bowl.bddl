    plate_1 plate_2 - plate
    akita_black_bowl_1 - akita_black_bowl
    akita_green_bowl_1 - akita_green_bowl
    orange_bowl_1 - orange_bowl
    orange_juice_1 - orange_juice
  )

  (:obj_of_interest
