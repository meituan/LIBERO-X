    (On chocolate_pudding_1 study_table_chocolate_pudding_A_init_region)
    (On chocolate_pudding_2 study_table_chocolate_pudding_B_init_region)
    (On black_book_1 study_table_black_book_init_region)
    (On orange_book_1 study_table_orange_book_init_region)
    (On milk_1 study_table_milk_init_region)
    (On akita_black_bowl_1 study_table_akita_black_bowl_init_region)
  )

  (:goal
