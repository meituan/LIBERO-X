            )
          )
      )
      (milk_init_region
          (:target study_table)
          (:ranges (
              (0.08100000000000002 0.101 0.199 0.219)
            )
          )
          (:yaw_rotation (
              (-3.142 3.142)
            )
          )
      )
      (chocolate_pudding_B_init_region
          (:target study_table)
          (:ranges (
              (0.0019999999999999983 0.052000000000000005 0.057999999999999996 0.108)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (chocolate_pudding_A_init_region
